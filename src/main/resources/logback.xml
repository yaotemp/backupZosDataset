<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ============================================================
         Log file path — override at runtime with:
           -Dlog.dir=/custom/path
         Default: ./logs
         ============================================================ -->
    <property name="LOG_DIR" value="${log.dir:-logs}" />
    <property name="LOG_FILE" value="dataset-backup" />

    <!-- ============================================================
         Console appender (stdout)
         ============================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ============================================================
         Rolling file appender
         - Daily rollover
         - Max 30 days of history
         - Max 100 MB total size
         ============================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ============================================================
         Root logger — INFO to both console and file
         ============================================================ -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
